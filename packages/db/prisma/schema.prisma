generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Owner
  Admin
  WarehouseStaff
  SalesStaff
  PurchasingStaff
  Viewer
}

enum StockMovementType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
  SALE
  PURCHASE_RECEIPT
  TRANSFER
  MANUFACTURE_CONSUME
  MANUFACTURE_PRODUCE
}

enum ManufacturingOrderStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PICKING
  PARTIALLY_PICKED
  PICKED
  PARTIALLY_PACKED
  PACKED
  PARTIALLY_SHIPPED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum StocktakeStatus {
  DRAFT
  COUNTING
  REVIEW
  COMPLETED
  CANCELLED
}

enum StocktakeItemStatus {
  PENDING
  COUNTED
  APPROVED
  REJECTED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum CreditNoteStatus {
  DRAFT
  ISSUED
  APPLIED
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  CHECK
  OTHER
}

enum SalesReturnStatus {
  DRAFT
  APPROVED
  COMPLETED
  CANCELLED
}

enum AuditAction {
  CREATE
  UPDATE
  CONFIRM
  RECEIVE
  CANCEL
  PICK
  PACK
  SHIP
  STOCKTAKE
}

enum WebhookSource {
  SHOPIFY
  WOOCOMMERCE
}

enum WebhookEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum NotificationChannel {
  SMS
  WHATSAPP
}

enum ShipmentStatus {
  PREPARING
  IN_TRANSIT
  DELIVERED
  RETURNED
}

enum PickListStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum AccountingProvider {
  XERO
  QUICKBOOKS
}

enum SyncDirection {
  PUSH
  PULL
}

enum SyncStatus {
  SUCCESS
  FAILED
  CONFLICT
}

enum ExtensionWebhookStatus {
  ACTIVE
  PAUSED
}

enum ExchangeRateProvider {
  ECB
  TCMB
  MANUAL
}

model Organization {
  id                     String                         @id @default(cuid())
  name                   String
  slug                   String                         @unique
  defaultCurrency        String                         @default("TRY")
  locale                 String                         @default("tr")
  createdAt              DateTime                       @default(now())
  updatedAt              DateTime                       @updatedAt
  apiTokens              ApiToken[]
  auditLogs              AuditLog[]
  customFields           CustomField[]
  customers              Customer[]
  exchangeRates          ExchangeRate[]
  invoices               Invoice[]
  idempotencyKeys        IdempotencyKey[]
  bins                   WarehouseBin[]
  inventoryLayers        InventoryLayer[]
  cogsEntries            COGSEntry[]
  memberships            Membership[]
  stockBalances          StockBalance[]
  stockReconciliations   StockReconciliation[]
  accountingConnections  AccountingConnection[]
  notificationDeliveries NotificationDelivery[]
  payments               Payment[]
  products               Product[]
  purchaseOrders         PurchaseOrder[]
  salesOrders            SalesOrder[]
  salesReturns           SalesReturn[]
  sessions               Session[]
  stockMovements         StockMovement[]
  suppliers              Supplier[]
  shipments              Shipment[]
  pickLists              PickList[]
  webhookEvents          WebhookEvent[]
  webhookSubscriptions   ExtensionWebhookSubscription[]
  warehouses             Warehouse[]
  billsOfMaterial        BillOfMaterial[]
  manufacturingOrders    ManufacturingOrder[]
  customerPriceTiers     CustomerPriceTier[]
  branding               OrganizationBranding?
  savedReports           SavedReport[]
  scheduledReports       ScheduledReport[]
  stocktakes             Stocktake[]
  creditNotes            CreditNote[]
}

model ExtensionWebhookSubscription {
  id             String                 @id @default(cuid())
  organizationId String
  url            String
  events         Json
  secret         String?
  status         ExtensionWebhookStatus @default(ACTIVE)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

model CustomField {
  id             String       @id @default(cuid())
  organizationId String
  entityType     String
  entityId       String
  key            String
  value          Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, entityType, entityId, key])
  @@index([organizationId, entityType, entityId])
}

model ExchangeRate {
  id             String               @id @default(cuid())
  organizationId String
  baseCurrency   String
  quoteCurrency  String
  rate           Decimal              @db.Decimal(18, 8)
  provider       ExchangeRateProvider
  observedAt     DateTime
  createdAt      DateTime             @default(now())
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider, baseCurrency, quoteCurrency, observedAt])
  @@index([organizationId, baseCurrency, quoteCurrency, observedAt])
}

model User {
  id                   String                @id @default(cuid())
  name                 String
  email                String                @unique
  passwordHash         String?
  twoFactorEnabled     Boolean               @default(false)
  createdAt            DateTime              @default(now())
  apiTokens            ApiToken[]
  auditLogs            AuditLog[]
  backupCodes          BackupCode[]
  idempotencyKeys      IdempotencyKey[]
  oAuthAccounts        OAuthAccount[]
  memberships          Membership[]
  totpSecret           TotpSecret?
  pickLists            PickList[]
  sessions             Session[]
  stockMovements       StockMovement[]
  stockReconciliations StockReconciliation[]
  savedReports         SavedReport[]
  stocktakes           Stocktake[]
}

model ApiToken {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  name           String
  tokenHash      String       @unique
  lastUsedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([revokedAt])
}

model IdempotencyKey {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  key            String
  method         String
  path           String
  requestHash    String
  statusCode     Int
  responseBody   Json
  createdAt      DateTime     @default(now())
  expiresAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId, expiresAt])
  @@index([userId])
}

model Session {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  tokenHash      String       @unique
  ipAddress      String?
  userAgent      String?
  lastActiveAt   DateTime     @default(now())
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
  @@index([expiresAt])
  @@index([lastActiveAt])
}

model Membership {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           Role
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Warehouse {
  id                  String               @id @default(cuid())
  organizationId      String
  code                String
  name                String
  isDefault           Boolean              @default(false)
  createdAt           DateTime             @default(now())
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryLayers     InventoryLayer[]
  pickLists           PickList[]
  stockMovements      StockMovement[]
  stockBalances       StockBalance[]
  stockReservations   StockReservation[]
  manufacturingOrders ManufacturingOrder[]
  stocktakes          Stocktake[]
  warehouseBins       WarehouseBin[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

model WarehouseBin {
  id              String           @id @default(cuid())
  warehouseId     String
  code            String
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  warehouse       Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stockBalances   StockBalance[]
  inventoryLayers InventoryLayer[]
  stockMovements  StockMovement[]
  pickListItems   PickListItem[]
  stocktakeItems  StocktakeItem[]
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId  String

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

model Product {
  id                 String              @id @default(cuid())
  organizationId     String
  sku                String
  name               String
  barcode            String?
  category           String
  description        String?
  unitPrice          Decimal             @default(0) @db.Decimal(12, 2)
  costPrice          Decimal?            @db.Decimal(12, 2)
  averageCost        Decimal?            @db.Decimal(12, 2)
  weight             Decimal?            @db.Decimal(10, 3)
  dimensionL         Decimal?            @db.Decimal(10, 2)
  dimensionW         Decimal?            @db.Decimal(10, 2)
  dimensionH         Decimal?            @db.Decimal(10, 2)
  minimumStock       Int                 @default(0)
  isActive           Boolean             @default(true)
  isBatchTracked     Boolean             @default(false)
  isSerialized       Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceLines       InvoiceLine[]
  inventoryLayers    InventoryLayer[]
  cogsEntries        COGSEntry[]
  purchaseOrderLines PurchaseOrderLine[]
  pickListItems      PickListItem[]
  returnLines        SalesReturnLine[]
  salesOrderLines    SalesOrderLine[]
  stockMovements     StockMovement[]
  stockBalances      StockBalance[]
  stockReservations  StockReservation[]
  suppliers          ProductSupplier[]
  variants           ProductVariant[]
  bom                BillOfMaterial?
  bomComponents      BomComponent[]      @relation("BomComponentProduct")
  priceTiers         CustomerPriceTier[]
  stocktakeItems     StocktakeItem[]
  creditNoteLines    CreditNoteLine[]

  @@unique([organizationId, sku])
  @@index([organizationId, barcode])
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  sku        String
  name       String
  barcode    String?
  unitPrice  Decimal  @default(0) @db.Decimal(12, 2)
  costPrice  Decimal? @db.Decimal(12, 2)
  weight     Decimal? @db.Decimal(8, 3)
  isActive   Boolean  @default(true)
  attributes Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, sku])
  @@index([productId])
}

model Supplier {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  contactName    String?
  email          String?
  phone          String?
  leadTimeDays   Int               @default(7)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products       ProductSupplier[]
  purchaseOrders PurchaseOrder[]

  @@unique([organizationId, name])
}

model ProductSupplier {
  productId  String
  supplierId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([productId, supplierId])
}

model StockMovement {
  id             String            @id @default(cuid())
  organizationId String
  warehouseId    String
  productId      String
  type           StockMovementType
  quantityChange Int
  reference      String?
  note           String?
  binId          String?
  lotNumber      String?
  serialNumber   String?
  expiryDate     DateTime?
  createdById    String?
  createdAt      DateTime          @default(now())
  createdBy      User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product        Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse      Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  bin            WarehouseBin?     @relation(fields: [binId], references: [id], onDelete: SetNull)
  cogsEntries    COGSEntry[]

  @@index([organizationId, productId, warehouseId])
  @@index([organizationId, createdAt])
}

model InventoryLayer {
  id              String        @id @default(cuid())
  organizationId  String
  productId       String
  warehouseId     String
  quantity        Int
  unitCost        Decimal       @db.Decimal(12, 4)
  binId           String?
  lotNumber       String?
  serialNumber    String?
  expiryDate      DateTime?
  receivedAt      DateTime      @default(now())
  purchaseOrderId String?
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  bin             WarehouseBin? @relation(fields: [binId], references: [id], onDelete: SetNull)

  @@index([organizationId, productId, warehouseId, receivedAt])
}

model COGSEntry {
  id             String        @id @default(cuid())
  organizationId String
  productId      String
  quantity       Int
  unitCost       Decimal       @db.Decimal(12, 4)
  totalCost      Decimal       @db.Decimal(12, 2)
  method         String
  movementId     String
  createdAt      DateTime      @default(now())
  movement       StockMovement @relation(fields: [movementId], references: [id], onDelete: Restrict)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product        Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([organizationId, productId])
}

model SalesOrder {
  id                String             @id @default(cuid())
  organizationId    String
  code              String
  customerId        String?
  customerName      String
  status            SalesOrderStatus   @default(DRAFT)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  customer          Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lines             SalesOrderLine[]
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  pickListItems     PickListItem[]
  returns           SalesReturn[]
  shipments         Shipment[]
  stockReservations StockReservation[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([customerId])
}

model SalesOrderLine {
  id           String     @id @default(cuid())
  salesOrderId String
  productId    String
  quantity     Int
  pickedQty    Int        @default(0)
  packedQty    Int        @default(0)
  shippedQty   Int        @default(0)
  unitPrice    Decimal    @default(0) @db.Decimal(12, 2)
  discount     Decimal    @default(0) @db.Decimal(5, 2)
  lineTotal    Decimal    @default(0) @db.Decimal(12, 2)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  organizationId String
  supplierId     String
  code           String
  status         PurchaseOrderStatus @default(DRAFT)
  expectedDate   DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  lines          PurchaseOrderLine[]
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier       Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  @@unique([organizationId, code])
  @@index([organizationId, status])
}

model PurchaseOrderLine {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  productId        String
  quantity         Int
  receivedQuantity Int           @default(0)
  unitCost         Decimal       @default(0) @db.Decimal(12, 2)
  discount         Decimal       @default(0) @db.Decimal(5, 2)
  lineTotal        Decimal       @default(0) @db.Decimal(12, 2)
  product          Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  actorId        String?
  action         AuditAction
  entityType     String
  entityId       String
  summary        String
  createdAt      DateTime     @default(now())
  actor          User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model WebhookEvent {
  id             String             @id @default(cuid())
  organizationId String
  source         WebhookSource
  topic          String
  externalId     String?
  dedupeKey      String             @unique
  status         WebhookEventStatus @default(PENDING)
  payload        Json
  headers        Json?
  error          String?
  attempts       Int                @default(0)
  receivedAt     DateTime           @default(now())
  processedAt    DateTime?
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, receivedAt])
  @@index([source, topic])
}

model NotificationDelivery {
  id             String                     @id @default(cuid())
  organizationId String
  channel        NotificationChannel
  provider       String
  recipient      String?
  message        String
  status         NotificationDeliveryStatus @default(PENDING)
  reason         String?
  error          String?
  createdAt      DateTime                   @default(now())
  sentAt         DateTime?
  organization   Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, createdAt])
  @@index([channel, provider])
}

model SalesReturn {
  id             String            @id @default(cuid())
  organizationId String
  salesOrderId   String
  code           String
  reason         String?
  status         SalesReturnStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  lines          SalesReturnLine[]
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrder     SalesOrder        @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)

  creditNotes CreditNote[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([salesOrderId])
}

model SalesReturnLine {
  id            String      @id @default(cuid())
  salesReturnId String
  productId     String
  quantity      Int
  restocked     Boolean     @default(false)
  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  product       Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Customer {
  id              String              @id @default(cuid())
  organizationId  String
  code            String
  name            String
  email           String?
  phone           String?
  taxId           String?
  address         String?
  paymentTermDays Int                 @default(30)
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices        Invoice[]
  salesOrders     SalesOrder[]
  customerUsers   CustomerUser[]
  priceTiers      CustomerPriceTier[]

  creditNotes CreditNote[]

  @@unique([organizationId, code])
  @@index([organizationId, name])
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  customerId     String
  code           String
  status         InvoiceStatus @default(DRAFT)
  issuedAt       DateTime?
  dueDate        DateTime?
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @db.Decimal(12, 2)
  taxRate        Decimal       @default(0) @db.Decimal(5, 4)
  taxAmount      Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @default(0) @db.Decimal(12, 2)
  currency       String        @default("TRY")
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines          InvoiceLine[]
  payments       Payment[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([customerId])
}

model InvoiceLine {
  id          String  @id @default(cuid())
  invoiceId   String
  productId   String
  description String?
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal @db.Decimal(12, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Payment {
  id             String        @id @default(cuid())
  organizationId String
  invoiceId      String
  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod @default(BANK_TRANSFER)
  reference      String?
  paidAt         DateTime      @default(now())
  createdAt      DateTime      @default(now())
  invoice        Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, paidAt])
  @@index([invoiceId])
}

model OAuthAccount {
  id             String    @id @default(cuid())
  userId         String
  provider       String
  providerUserId String
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model TotpSecret {
  id              String   @id @default(cuid())
  userId          String   @unique
  encryptedSecret String
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BackupCode {
  id       String    @id @default(cuid())
  userId   String
  codeHash String
  usedAt   DateTime?
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AccountingConnection {
  id             String              @id @default(cuid())
  organizationId String
  provider       AccountingProvider
  tenantId       String
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  lastSyncAt     DateTime?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncLogs       AccountingSyncLog[]

  @@unique([organizationId, provider])
  @@index([organizationId])
}

model AccountingSyncLog {
  id           String               @id @default(cuid())
  connectionId String
  direction    SyncDirection
  entityType   String
  entityId     String
  externalId   String?
  status       SyncStatus
  error        String?
  resolvedAt   DateTime?
  createdAt    DateTime             @default(now())
  connection   AccountingConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([connectionId, createdAt])
  @@index([entityType, entityId])
}

model Shipment {
  id             String         @id @default(cuid())
  organizationId String
  salesOrderId   String
  code           String
  carrier        String?
  trackingNumber String?
  trackingUrl    String?
  weight         Decimal?       @db.Decimal(8, 3)
  packageCount   Int            @default(1)
  status         ShipmentStatus @default(PREPARING)
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime       @default(now())
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrder     SalesOrder     @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([salesOrderId])
}

model PickList {
  id             String         @id @default(cuid())
  organizationId String
  warehouseId    String
  assignedToId   String?
  status         PickListStatus @default(PENDING)
  priority       Int            @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  assignedTo     User?          @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  items          PickListItem[]
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([organizationId, status])
  @@index([warehouseId])
  @@index([assignedToId])
}

model PickListItem {
  id           String        @id @default(cuid())
  pickListId   String
  salesOrderId String
  productId    String
  quantity     Int
  pickedQty    Int           @default(0)
  binId        String?
  lotNumber    String?
  serialNumber String?
  expiryDate   DateTime?
  notes        String?
  pickList     PickList      @relation(fields: [pickListId], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  salesOrder   SalesOrder    @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  bin          WarehouseBin? @relation(fields: [binId], references: [id], onDelete: SetNull)

  @@index([pickListId])
  @@index([salesOrderId])
  @@index([productId])
}

// ── Stock Balance & Reservations (Phase 8) ──

model StockBalance {
  id             String        @id @default(cuid())
  organizationId String
  productId      String
  warehouseId    String
  onHand         Int           @default(0)
  reserved       Int           @default(0)
  available      Int           @default(0)
  binId          String?
  lotNumber      String?
  serialNumber   String?
  expiryDate     DateTime?
  version        Int           @default(0)
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product        Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse      Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  bin            WarehouseBin? @relation(fields: [binId], references: [id], onDelete: SetNull)

  @@unique([organizationId, productId, warehouseId, binId, lotNumber, serialNumber])
  @@index([organizationId])
}

model StockReservation {
  id             String     @id @default(cuid())
  organizationId String
  salesOrderId   String
  productId      String
  warehouseId    String
  quantity       Int
  createdAt      DateTime   @default(now())
  salesOrder     SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product        Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse      Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([organizationId, salesOrderId])
  @@index([organizationId, productId, warehouseId])
}

model StockReconciliation {
  id             String       @id @default(cuid())
  organizationId String
  status         String       @default("COMPLETED")
  totalChecked   Int          @default(0)
  mismatchCount  Int          @default(0)
  autoFixed      Int          @default(0)
  details        Json         @default("[]")
  createdById    String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
}

// ── BOM + Manufacturing ──

model BillOfMaterial {
  id                  String               @id @default(cuid())
  organizationId      String
  productId           String               @unique
  name                String
  description         String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product             Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  components          BomComponent[]
  manufacturingOrders ManufacturingOrder[]

  @@index([organizationId])
}

model BomComponent {
  id                 String         @id @default(cuid())
  bomId              String
  componentProductId String
  quantity           Decimal        @db.Decimal(12, 4)
  sortOrder          Int            @default(0)
  bom                BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentProduct   Product        @relation("BomComponentProduct", fields: [componentProductId], references: [id], onDelete: Restrict)

  @@index([bomId])
}

model ManufacturingOrder {
  id             String                   @id @default(cuid())
  organizationId String
  bomId          String
  warehouseId    String
  code           String
  quantity       Int
  status         ManufacturingOrderStatus @default(DRAFT)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bom            BillOfMaterial           @relation(fields: [bomId], references: [id], onDelete: Restrict)
  warehouse      Warehouse                @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@unique([organizationId, code])
  @@index([organizationId, status])
}

// ── B2B Portal ──

model CustomerUser {
  id           String            @id @default(cuid())
  customerId   String
  name         String
  email        String            @unique
  passwordHash String
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  customer     Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  sessions     CustomerSession[]

  @@index([customerId])
}

model CustomerSession {
  id             String       @id @default(cuid())
  customerUserId String
  tokenHash      String       @unique
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  customerUser   CustomerUser @relation(fields: [customerUserId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model CustomerPriceTier {
  id             String       @id @default(cuid())
  organizationId String
  customerId     String
  productId      String
  tierPrice      Decimal      @db.Decimal(12, 2)
  minQuantity    Int          @default(1)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  product        Product      @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([organizationId, customerId, productId, minQuantity])
  @@index([customerId, productId])
}

model OrganizationBranding {
  id             String       @id @default(cuid())
  organizationId String       @unique
  logoUrl        String?
  primaryColor   String?
  accentColor    String?
  portalDomain   String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ── Reports ──

model SavedReport {
  id                 String            @id @default(cuid())
  organizationId     String
  name               String
  reportDefinitionId String
  columns            Json
  filters            Json
  dateRange          Json?
  createdById        String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  organization       Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy          User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  scheduledReports   ScheduledReport[]

  @@index([organizationId])
}

model ScheduledReport {
  id             String       @id @default(cuid())
  organizationId String
  savedReportId  String
  frequency      String
  recipients     Json
  nextRunAt      DateTime
  lastRunAt      DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  savedReport    SavedReport  @relation(fields: [savedReportId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([isActive, nextRunAt])
}

model Stocktake {
  id             String          @id @default(cuid())
  organizationId String
  warehouseId    String
  status         StocktakeStatus @default(DRAFT)
  assignedToId   String?
  scheduledFor   DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse      Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  assignedTo     User?           @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  items          StocktakeItem[]

  @@index([organizationId, status])
  @@index([warehouseId])
}

model StocktakeItem {
  id          String              @id @default(cuid())
  stocktakeId String
  productId   String
  binId       String?
  expectedQty Int                 @default(0)
  countedQty  Int?
  variance    Int?
  status      StocktakeItemStatus @default(PENDING)
  stocktake   Stocktake           @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  product     Product             @relation(fields: [productId], references: [id], onDelete: Restrict)
  bin         WarehouseBin?       @relation(fields: [binId], references: [id], onDelete: SetNull)

  @@index([stocktakeId])
  @@index([productId])
}

// ── Credit Notes ──

model CreditNote {
  id             String           @id @default(cuid())
  organizationId String
  customerId     String
  salesReturnId  String?
  code           String
  status         CreditNoteStatus @default(DRAFT)
  totalAmount    Decimal          @default(0) @db.Decimal(12, 2)
  appliedAmount  Decimal          @default(0) @db.Decimal(12, 2)
  issuedAt       DateTime?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  salesReturn    SalesReturn?     @relation(fields: [salesReturnId], references: [id], onDelete: SetNull)
  lines          CreditNoteLine[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@index([customerId])
}

model CreditNoteLine {
  id           String     @id @default(cuid())
  creditNoteId String
  productId    String
  quantity     Int
  unitPrice    Decimal    @db.Decimal(12, 2)
  lineTotal    Decimal    @db.Decimal(12, 2)
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
}
