# ── Feature Flags ──
# Controls which nav items / surfaces are visible to users.
# Set to "true" to enable; leave empty or omit to hide (default).
# Production deployments should leave experimental features disabled.
NEXT_PUBLIC_FEATURE_MANUFACTURING=""          # Üretim (BOM / MO) — hide until battle-tested
NEXT_PUBLIC_FEATURE_ANALYTICS=""              # Analitik — chart bug, sparse data
NEXT_PUBLIC_FEATURE_FORECASTING=""            # Tahmin — needs 6+ months of history
NEXT_PUBLIC_FEATURE_REPORTS=""                # Raporlar — individual reports unverified
NEXT_PUBLIC_FEATURE_CREDIT_NOTES=""           # Kredi Notları — v1.1 candidate
