{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "prisma:validate": {
      "cache": false
    },
    "prisma:generate": {
      "cache": false
    },
    "prisma:migrate:check": {
      "cache": false
    },
    "prisma:migrate:dev": {
      "cache": false
    },
    "prisma:migrate:deploy": {
      "cache": false
    },
    "prisma:migrate:status": {
      "cache": false
    },
    "prisma:push": {
      "cache": false
    },
    "prisma:seed": {
      "cache": false
    }
  }
}
