{
  "name": "stockops",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/integrations/*"
  ],
  "scripts": {
    "dev": "turbo dev --filter=@stockops/web",
    "dev:all": "turbo dev --parallel",
    "dev:web": "turbo dev --filter=@stockops/web",
    "dev:api": "turbo dev --filter=@stockops/api",
    "dev:worker": "turbo dev --filter=@stockops/worker",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:ps": "docker compose ps",
    "db:reset:local": "docker compose down -v",
    "db:up": "docker compose up -d postgres",
    "build": "turbo build",
    "lint": "turbo lint --filter=@stockops/web",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "prisma:validate": "turbo prisma:validate --filter=@stockops/db",
    "prisma:generate": "turbo prisma:generate --filter=@stockops/db",
    "prisma:migrate:check": "turbo prisma:migrate:check --filter=@stockops/db",
    "prisma:migrate:dev": "turbo prisma:migrate:dev --filter=@stockops/db",
    "prisma:migrate:deploy": "turbo prisma:migrate:deploy --filter=@stockops/db",
    "prisma:migrate:status": "turbo prisma:migrate:status --filter=@stockops/db",
    "prisma:push": "turbo prisma:push --filter=@stockops/db",
    "prisma:seed": "turbo prisma:seed --filter=@stockops/db",
    "smoke:database": "npm run smoke:database --workspace @stockops/api"
  },
  "devDependencies": {
    "turbo": "^2.8.0"
  },
  "dependencies": {
    "@google/genai": "^1.50.1"
  }
}
